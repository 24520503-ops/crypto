{
  "name": "besu-local-client",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal Hyperledger Besu local node and JSON-RPC client",
  "dependencies": {
    "ethers": "^6.15.0"
  },
  "scripts": {
    "start:node": "bash ./setup.sh all",
    "stop:node": "pkill -f '/app/build/install/besu/bin/besu' || true",
    "client": "node client.js",
    "client:sign": "node sign-client.js",
    "client:raw": "node raw-rpc-client.js",
    "client:mine": "node mined-transaction-client.js"
  }
}
